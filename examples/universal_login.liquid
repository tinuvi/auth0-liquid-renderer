<!doctype html>
<html lang="{{ locale | default: 'pt-BR' }}">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ application.name }} · Entrar</title>
{%- auth0:head -%}
<style>
:root{--ink:#15151a;--ink2:#56565e;--ink3:#8d8d96;--line:#e7e7ec;--soft:#f4f4f6;--paper:#ffffff;--sans:-apple-system,BlinkMacSystemFont,"Segoe UI","Helvetica Neue",Helvetica,Arial,sans-serif;--mono:ui-monospace,"SF Mono",Menlo,Consolas,monospace}
*{box-sizing:border-box}html,body{height:100%}
body{margin:0;font-family:var(--sans);color:var(--ink);background:var(--paper);-webkit-font-smoothing:antialiased}
.ulp{min-height:100vh;display:grid;grid-template-columns:1.04fr 1fr}
.ulp-brand{position:relative;background:var(--ink);color:#fff;padding:46px 50px;display:flex;flex-direction:column;justify-content:space-between;overflow:hidden}
.bp-pattern{position:absolute;inset:0;opacity:.06;background-image:radial-gradient(#fff 1.2px,transparent 1.2px);background-size:26px 26px}
.bp-top{position:relative;display:flex;align-items:center;gap:11px}
.bp-mono{width:34px;height:34px;color:#fff}.bp-mono svg{width:34px;height:34px}
.bp-name{font-size:18px;font-weight:700;letter-spacing:-.01em}
.bp-mid{position:relative}
.bp-h{font-size:33px;line-height:1.16;font-weight:700;letter-spacing:-.02em;max-width:13ch;text-wrap:balance}
.bp-sub{font-size:15px;line-height:1.6;color:rgba(255,255,255,.6);margin-top:16px;max-width:32ch}
.bp-foot{position:relative;font-size:12px;color:rgba(255,255,255,.42);display:flex;gap:18px}
.bp-foot a{color:rgba(255,255,255,.55);text-decoration:none}
.ulp-main{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:48px 32px;background:var(--paper)}
.ulp-widget{width:100%;max-width:372px}
.ulp-foot{margin-top:26px;font-size:12px;color:var(--ink3);text-align:center}
.ulp-foot a{color:var(--ink2);text-decoration:underline}
@media (max-width:780px){.ulp{grid-template-columns:1fr}.ulp-brand{display:none}.ulp-main{min-height:100vh}}
</style>
</head>
<body>
<main class="ulp">
<aside class="ulp-brand">
<div class="bp-pattern"></div>
<div class="bp-top"><span class="bp-mono"><svg viewBox="0 0 28 28" width="28" height="28" fill="none" aria-hidden="true"><rect x="1.2" y="1.2" width="25.6" height="25.6" rx="7" stroke="currentColor" stroke-width="1.5"/><rect x="9.4" y="9.4" width="9.2" height="9.2" rx="2" transform="rotate(45 14 14)" fill="currentColor"/></svg></span><span class="bp-name">{{ application.name }}</span></div>
<div class="bp-mid">
<div class="bp-h">Acesse sua conta com segurança</div>
<p class="bp-sub">Autenticação unificada para os aplicativos da {% if organization.display_name %}{{ organization.display_name }}{% else %}{{ application.name }}{% endif %}</p>
</div>
<div class="bp-foot"><span>© {{ application.name }}</span><a href="#">Privacidade</a><a href="#">Termos</a></div>
</aside>
<section class="ulp-main">
<div class="ulp-widget">
{%- auth0:widget -%}
</div>
<div class="ulp-foot">Protegido por {{ application.name }} · <a href="#">Ajuda</a></div>
</section>
</main>
</body>
</html>
