<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Your authentication code</title>
  </head>
  <body style="margin:0;background:#f5f6fc;font-family:Arial,Helvetica,sans-serif;color:#1a1a2e">
    <div style="max-width:480px;margin:32px auto;background:#fff;border-radius:8px;padding:32px">
      <img src="{{ application.logo_uri }}" alt="{{ application.name }}" height="40" />
      <h1 style="font-size:20px">Your authentication code</h1>
      <p>Hi {{ user.email }},</p>
      <p>Enter this one-time code to finish signing in to {{ application.name }}:</p>
      <p style="font-size:30px;letter-spacing:6px;font-weight:bold;margin:24px 0">{{ code }}</p>
      <p style="color:#666;font-size:13px">This code expires shortly. Didn't try to sign in? Contact
        <a href="{{ support_url }}">support</a>.</p>
    </div>
  </body>
</html>
