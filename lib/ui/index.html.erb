<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>E-mails de identidade · pt-BR</title>
  <style>
    /* Previewer shell — neutral monochrome app chrome around the emails (ported from
       the Claude Design prototype's app.css, verbatim). */
    :root{
      --bg:#f1f1f3; --panel:#ffffff; --line:#e7e7ec; --line-2:#eef0f2;
      --ink:#15151a; --ink-2:#56565e; --ink-3:#8d8d96; --ink-soft:#f4f4f6;
      --mono:ui-monospace,"SF Mono",Menlo,Consolas,monospace;
      --sans:-apple-system,BlinkMacSystemFont,"Segoe UI","Helvetica Neue",Helvetica,Arial,sans-serif;
      --rail:300px;
    }
    *{box-sizing:border-box}
    html,body{height:100%}
    body{margin:0;background:var(--bg);font-family:var(--sans);color:var(--ink);-webkit-font-smoothing:antialiased}
    #app{height:100vh}
    button{font-family:inherit;cursor:pointer}
    svg{display:block}

    .app{display:flex;height:100vh;overflow:hidden}

    /* ---- Sidebar ---- */
    .rail{width:var(--rail);flex:0 0 var(--rail);background:var(--panel);border-right:1px solid var(--line);
      display:flex;flex-direction:column;transition:margin-left .26s cubic-bezier(.4,0,.2,1)}
    .app.collapsed .rail{margin-left:calc(var(--rail) * -1)}
    .rail-head{padding:18px 18px 12px;border-bottom:1px solid var(--line)}
    .brand{display:flex;align-items:center;gap:10px;color:var(--ink)}
    .brand .mk{width:26px;height:26px;color:var(--ink)}
    .brand .mk svg{width:26px;height:26px}
    .brand-t{font-size:14.5px;font-weight:700;letter-spacing:-.01em}
    .brand-s{font-size:11px;color:var(--ink-3);margin-top:1px;font-family:var(--mono);letter-spacing:.02em}
    .search{position:relative;margin-top:14px}
    .search svg{position:absolute;left:11px;top:50%;transform:translateY(-50%);width:15px;height:15px;color:var(--ink-3)}
    .search input{width:100%;border:1px solid var(--line);background:var(--bg);border-radius:9px;
      padding:9px 12px 9px 33px;font-size:13px;color:var(--ink);outline:none;font-family:inherit}
    .search input:focus{border-color:#c9c9d1;background:#fff}
    .search input::placeholder{color:var(--ink-3)}

    .nav{flex:1;overflow-y:auto;padding:12px 12px 24px}
    .nav-group{font-family:var(--mono);font-size:10.5px;letter-spacing:.14em;text-transform:uppercase;
      color:var(--ink-3);padding:16px 10px 8px}
    .nav-group:first-child{padding-top:6px}
    .item{display:flex;align-items:center;gap:11px;width:100%;text-align:left;border:0;background:none;
      padding:9px 10px;border-radius:9px;color:var(--ink-2);transition:background .12s}
    .item:hover{background:var(--ink-soft)}
    .item.active{background:var(--ink);color:#fff}
    .item-ic{width:20px;height:20px;flex:0 0 20px;color:currentColor;opacity:.9}
    .item-ic svg{width:20px;height:20px}
    .item-tx{min-width:0}
    .item-t{font-size:13px;font-weight:600;color:var(--ink);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .item.active .item-t{color:#fff}
    .item-d{font-size:11px;color:var(--ink-3);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-top:1px}
    .item.active .item-d{color:rgba(255,255,255,.6)}

    /* ---- Main ---- */
    .main{flex:1;display:flex;flex-direction:column;min-width:0}
    .bar{height:56px;flex:0 0 56px;background:var(--panel);border-bottom:1px solid var(--line);
      display:flex;align-items:center;gap:14px;padding:0 16px}
    .icon-btn{width:34px;height:34px;border:1px solid var(--line);background:#fff;border-radius:8px;
      display:flex;align-items:center;justify-content:center;color:var(--ink-2)}
    .icon-btn:hover{background:var(--ink-soft);color:var(--ink)}
    .icon-btn svg{width:18px;height:18px}
    .bar-title{min-width:0}
    .bar-title .t{font-size:13.5px;font-weight:700;letter-spacing:-.01em;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .bar-title .s{font-size:11px;color:var(--ink-3);font-family:var(--mono)}
    .spacer{flex:1}

    .seg{display:flex;background:var(--bg);border:1px solid var(--line);border-radius:9px;padding:3px;gap:2px}
    .seg button{border:0;background:none;border-radius:6px;padding:6px 11px;font-size:12.5px;font-weight:600;
      color:var(--ink-2);display:flex;align-items:center;gap:6px;line-height:1}
    .seg button svg{width:16px;height:16px}
    .seg button:hover{color:var(--ink)}
    .seg button.on{background:#fff;color:var(--ink);box-shadow:0 1px 2px rgba(0,0,0,.06)}
    .seg.disabled{opacity:.4;pointer-events:none}
    .seg.icons button{padding:6px 9px}
    .seg-label{font-family:var(--mono);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-3);margin-right:-6px;align-self:center}

    /* ---- Variables button + drawer ---- */
    .vars-btn{display:flex;align-items:center;gap:7px;border:1px solid var(--line);background:#fff;border-radius:9px;
      padding:7px 12px;font-size:12.5px;font-weight:600;color:var(--ink-2);position:relative}
    .vars-btn:hover{background:var(--ink-soft);color:var(--ink)}
    .vars-btn.on{background:var(--ink);color:#fff;border-color:var(--ink)}
    .vars-btn svg{width:16px;height:16px}
    .vars-badge{display:inline-flex;align-items:center;justify-content:center;min-width:17px;height:17px;padding:0 4px;
      border-radius:9px;background:var(--ink);color:#fff;font-size:10.5px;font-weight:700;font-family:var(--mono)}
    .vars-btn.on .vars-badge{background:#fff;color:var(--ink)}

    .main{position:relative}
    .main.with-drawer .stage{padding-right:380px}
    .drawer{position:absolute;top:56px;right:0;bottom:0;width:356px;background:var(--panel);border-left:1px solid var(--line);
      box-shadow:-24px 0 48px -36px rgba(20,20,30,.3);display:flex;flex-direction:column;z-index:12;
      animation:drawerIn .22s cubic-bezier(.4,0,.2,1)}
    @keyframes drawerIn{from{transform:translateX(16px);opacity:.4}to{transform:none;opacity:1}}
    .drawer-head{display:flex;align-items:flex-start;justify-content:space-between;gap:12px;padding:16px 16px 12px;border-bottom:1px solid var(--line)}
    .drawer-t{font-size:14px;font-weight:700;letter-spacing:-.01em}
    .drawer-s{font-size:11.5px;color:var(--ink-3);font-family:var(--mono);margin-top:2px}
    .drawer-note{font-size:11.5px;line-height:1.5;color:var(--ink-3);padding:12px 16px;background:var(--bg);border-bottom:1px solid var(--line)}
    .drawer-body{flex:1;overflow-y:auto;padding:8px 16px 20px}
    .fgroup{padding-top:14px}
    .fgroup-t{font-family:var(--mono);font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--ink-3);padding:8px 0 10px}
    .field{margin-bottom:13px}
    .field-top{display:flex;align-items:center;justify-content:space-between;gap:8px;margin-bottom:5px}
    .field-l{font-size:12px;font-weight:600;color:var(--ink)}
    .field.changed .field-l::after{content:'';display:inline-block;width:5px;height:5px;border-radius:50%;background:var(--ink);margin-left:6px;vertical-align:middle}
    .field-revert{border:0;background:none;color:var(--ink-3);width:22px;height:22px;display:flex;align-items:center;justify-content:center;border-radius:6px}
    .field:not(.changed) .field-revert{display:none}
    .field-revert:hover{background:var(--ink-soft);color:var(--ink)}
    .field-revert svg{width:14px;height:14px}
    .field-i{width:100%;border:1px solid var(--line);background:var(--bg);border-radius:8px;padding:9px 11px;
      font-size:13px;color:var(--ink);outline:none;font-family:inherit}
    .field-i:focus{border-color:#bcbcc6;background:#fff}
    .field.changed .field-i{border-color:#bcbcc6;background:#fff}
    .field-tok{font-family:var(--mono);font-size:10.5px;color:var(--ink-3);margin-top:4px;word-break:break-all}
    .drawer-foot{padding:12px 16px;border-top:1px solid var(--line)}
    .reset-btn{width:100%;border:1px solid var(--line);background:#fff;border-radius:9px;padding:10px;font-size:12.5px;font-weight:600;color:var(--ink)}
    .reset-btn:hover:not(:disabled){background:var(--ink-soft)}
    .reset-btn:disabled{color:var(--ink-3);cursor:default;background:var(--bg)}

    /* ---- Stage ---- */
    .stage{flex:1;overflow:auto;background:var(--bg);
      background-image:radial-gradient(var(--line) 1px,transparent 1px);background-size:22px 22px;
      display:flex;justify-content:safe center;padding:34px 24px 60px}
    .client{align-self:flex-start;flex:0 0 auto;background:#fff;border:1px solid var(--line);border-radius:14px;
      box-shadow:0 1px 2px rgba(20,20,30,.04),0 24px 48px -28px rgba(20,20,30,.28);overflow:hidden;
      display:flex;flex-direction:column;
      transition:width .3s cubic-bezier(.4,0,.2,1),height .3s cubic-bezier(.4,0,.2,1)}
    .client-bar{height:38px;display:flex;align-items:center;gap:7px;padding:0 14px;border-bottom:1px solid var(--line-2);background:#fcfcfd}
    .dot{width:10px;height:10px;border-radius:50%;background:#e0e0e6}
    .client-bar .lbl{flex:1;text-align:center;font-size:11px;color:var(--ink-3);font-family:var(--mono);letter-spacing:.02em}
    .client-bar .w{font-size:11px;color:var(--ink-3);font-family:var(--mono)}
    .client-bar.browser .addr{flex:1;display:flex;align-items:center;justify-content:center;gap:7px;max-width:340px;margin:0 auto;background:#fff;border:1px solid var(--line-2);border-radius:7px;padding:4px 12px;font-size:11.5px;color:var(--ink-2);font-family:var(--mono)}
    .client-bar.browser .addr svg{width:12px;height:12px;color:var(--ink-3)}
    .client-meta{display:flex;align-items:flex-start;gap:12px;padding:14px 18px;border-bottom:1px solid var(--line-2)}
    .avatar{width:38px;height:38px;flex:0 0 38px;border-radius:50%;background:var(--ink);color:#fff;
      display:flex;align-items:center;justify-content:center}
    .avatar svg{width:20px;height:20px}
    .meta-tx{min-width:0;flex:1}
    .meta-subj{font-size:14px;font-weight:700;color:var(--ink);letter-spacing:-.01em;line-height:1.3;margin-bottom:3px;text-wrap:pretty}
    .meta-from{font-size:12px;color:var(--ink-2)}
    .meta-from b{color:var(--ink);font-weight:600}
    .meta-to{font-size:11.5px;color:var(--ink-3);margin-top:1px}
    .meta-time{font-size:11px;color:var(--ink-3);font-family:var(--mono);white-space:nowrap;padding-top:2px}
    .frame-wrap{background:#ebebed;flex:1;overflow-y:auto;overflow-x:hidden}
    .frame-wrap::-webkit-scrollbar{width:10px}
    .frame-wrap::-webkit-scrollbar-thumb{background:#cfcfd6;border-radius:8px;border:3px solid #ebebed}
    .frame-wrap iframe{display:block;width:100%;border:0;background:#ebebed}

    /* ---- Source view ---- */
    .source{align-self:flex-start;width:min(960px,100%);background:#fff;border:1px solid var(--line);
      border-radius:14px;overflow:hidden;box-shadow:0 24px 48px -32px rgba(20,20,30,.25)}
    .source-bar{display:flex;align-items:center;gap:10px;padding:11px 14px;border-bottom:1px solid var(--line-2);background:#fcfcfd}
    .source-bar .nm{font-family:var(--mono);font-size:12px;color:var(--ink-2)}
    .source-bar .nm b{color:var(--ink)}
    .copy-btn{display:flex;align-items:center;gap:6px;border:1px solid var(--line);background:#fff;border-radius:7px;
      padding:6px 11px;font-size:12px;font-weight:600;color:var(--ink-2)}
    .copy-btn:hover{background:var(--ink-soft);color:var(--ink)}
    .copy-btn svg{width:14px;height:14px}
    .source pre{margin:0;padding:18px 20px;font-family:var(--mono);font-size:12px;line-height:1.65;
      color:#2a2a31;white-space:pre-wrap;word-break:break-word;max-height:calc(100vh - 200px);overflow:auto}
    .source pre .lq{color:#9a5b00;font-weight:600}

    .float-open{position:fixed;left:14px;top:11px;z-index:20;display:none}
    .app.collapsed .float-open{display:flex}

    .stage-empty{margin:auto;color:var(--ink-3);font-size:13px}

    @media (max-width:760px){
      :root{--rail:264px}
      .app .rail{position:absolute;z-index:15;height:100%;box-shadow:0 24px 48px -24px rgba(0,0,0,.3)}
      .seg-label{display:none}
    }
  </style>
</head>
<body>
  <script>
    window.__ENTRIES__   = <%= @entries.to_json %>;
    window.__FIXVARS__   = <%= @fixture_vars.to_json %>;
    window.__THEMES__    = <%= @themes.to_json %>;
    window.__GROUPS__    = <%= @group_order.to_json %>;
  </script>
  <div class="app" id="app">
    <aside class="rail">
      <div class="rail-head">
        <div class="brand">
          <span class="mk" id="brand-mono"></span>
          <div>
            <div class="brand-t">E-mails de identidade</div>
            <div class="brand-s">pt-BR · Liquid · Auth0</div>
          </div>
        </div>
        <div class="search"><span id="search-ic"></span><input id="search" placeholder="Buscar template…" autocomplete="off"></div>
      </div>
      <nav class="nav" id="nav"></nav>
    </aside>
    <button class="icon-btn float-open" id="float-open" title="Mostrar lista"></button>
    <div class="main" id="main">
      <div class="bar" id="bar"></div>
      <div class="stage" id="stage"></div>
      <div id="drawer-host"></div>
    </div>
  </div>

  <script>
  (function () {
    "use strict";
    var ENTRIES = window.__ENTRIES__ || [];
    var FIXVARS = window.__FIXVARS__ || {};
    var THEMES  = window.__THEMES__ || [{ key: "quiet", label: "Quiet" }];
    var GROUPS  = window.__GROUPS__ || [];

    var BYNAME = {};
    ENTRIES.forEach(function (e) { BYNAME[e.name] = e; });

    // ---- crafted SVGs (ported from the design's assets.js) ----
    function ic(inner) {
      return '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" ' +
        'stroke-linecap="round" stroke-linejoin="round" width="100%" height="100%" aria-hidden="true">' + inner + '</svg>';
    }
    var ENVELOPE = '<rect x="3" y="5" width="18" height="14" rx="2.2"/><path d="M3.5 7.2 12 13l8.5-5.8"/>';
    var SHIELD = '<path d="M12 3 5 5.6v5.2c0 4.2 2.9 7.6 7 9.2 4.1-1.6 7-5 7-9.2V5.6L12 3Z"/>';
    var MAIL_ICONS = {
      welcome_email: ic('<path d="M12 3.5v3.2M12 17.3v3.2M3.5 12h3.2M17.3 12h3.2M6 6l2.2 2.2M15.8 15.8 18 18M18 6l-2.2 2.2M8.2 15.8 6 18"/><circle cx="12" cy="12" r="3.1"/>'),
      verify_email: ic(ENVELOPE + '<circle cx="18" cy="17.5" r="4.2" fill="#fff"/><path d="m16.2 17.6 1.2 1.2 2.4-2.6"/>'),
      verify_email_by_code: ic(ENVELOPE + '<circle cx="8.5" cy="16.5" r=".7" fill="currentColor" stroke="none"/><circle cx="12" cy="16.5" r=".7" fill="currentColor" stroke="none"/><circle cx="15.5" cy="16.5" r=".7" fill="currentColor" stroke="none"/>'),
      user_invitation: ic('<circle cx="9" cy="8.5" r="3"/><path d="M3.5 19.5a5.5 5.5 0 0 1 11 0"/><path d="M18 7.5v5M20.5 10h-5"/>'),
      reset_email: ic('<circle cx="8" cy="15" r="3.3"/><path d="m10.3 12.7 7-7M14.8 8.2l2.2 2.2M16.6 6.4l2 2"/>'),
      reset_email_by_code: ic('<circle cx="7.5" cy="15.5" r="3"/><path d="m9.6 13.4 6.4-6.4 2 2"/><circle cx="20" cy="16" r=".7" fill="currentColor" stroke="none"/><circle cx="20" cy="19" r=".7" fill="currentColor" stroke="none"/><circle cx="17" cy="19" r=".7" fill="currentColor" stroke="none"/>'),
      mfa_oob_code: ic(SHIELD + '<circle cx="9" cy="11.7" r=".75" fill="currentColor" stroke="none"/><circle cx="12" cy="11.7" r=".75" fill="currentColor" stroke="none"/><circle cx="15" cy="11.7" r=".75" fill="currentColor" stroke="none"/>'),
      enrollment_email: ic(SHIELD + '<path d="M12 9v5M9.5 11.5h5"/>'),
      blocked_account: ic(SHIELD + '<path d="m9.6 9.6 4.8 4.8M14.4 9.6l-4.8 4.8"/>'),
      stolen_credentials: ic('<path d="M12 3.5 2.8 19.5h18.4L12 3.5Z"/><path d="M12 10v4"/><circle cx="12" cy="16.8" r=".85" fill="currentColor" stroke="none"/>'),
      universal_login: ic('<rect x="3" y="4.5" width="18" height="15" rx="2.2"/><path d="M3 9h18"/><circle cx="6" cy="6.75" r=".6" fill="currentColor" stroke="none"/><circle cx="8" cy="6.75" r=".6" fill="currentColor" stroke="none"/><circle cx="12" cy="13" r="1.7"/><path d="M9.2 17a2.8 2.8 0 0 1 5.6 0"/>')
    };
    function monogram() {
      return '<svg viewBox="0 0 28 28" width="28" height="28" fill="none" aria-hidden="true">' +
        '<rect x="1.2" y="1.2" width="25.6" height="25.6" rx="7" stroke="currentColor" stroke-width="1.5"/>' +
        '<rect x="9.4" y="9.4" width="9.2" height="9.2" rx="2" transform="rotate(45 14 14)" fill="currentColor"/></svg>';
    }
    function ui(inner, sw) {
      return '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="' + (sw || 1.7) +
        '" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">' + inner + '</svg>';
    }
    var UI = {
      phone: ui('<rect x="7" y="3" width="10" height="18" rx="2.4"/><path d="M11 18h2"/>'),
      tablet: ui('<rect x="5" y="3" width="14" height="18" rx="2.2"/><path d="M11 18h2"/>'),
      desktop: ui('<rect x="3" y="4.5" width="18" height="12" rx="2"/><path d="M9 20.5h6M12 16.5v4"/>'),
      portrait: ui('<rect x="7" y="3" width="10" height="18" rx="2.4"/>'),
      landscape: ui('<rect x="3" y="7" width="18" height="10" rx="2.4"/>'),
      sidebar: ui('<rect x="3" y="4.5" width="18" height="15" rx="2.2"/><path d="M9 4.5v15"/>'),
      eye: ui('<path d="M2.5 12S6 5.5 12 5.5 21.5 12 21.5 12 18 18.5 12 18.5 2.5 12 2.5 12Z"/><circle cx="12" cy="12" r="2.6"/>'),
      code: ui('<path d="m9 8-4 4 4 4M15 8l4 4-4 4"/>'),
      copy: ui('<rect x="9" y="9" width="11" height="11" rx="2"/><path d="M5 15V6a2 2 0 0 1 2-2h9"/>'),
      check: ui('<path d="m5 12.5 4.5 4.5L19 6.5"/>', 2),
      search: ui('<circle cx="11" cy="11" r="6.5"/><path d="m20 20-3.5-3.5"/>'),
      sliders: ui('<path d="M4 7h9M19 7h1M4 12h1M11 12h9M4 17h6M16 17h4"/><circle cx="16" cy="7" r="2.3"/><circle cx="8" cy="12" r="2.3"/><circle cx="13" cy="17" r="2.3"/>'),
      close: ui('<path d="M6 6l12 12M18 6 6 18"/>'),
      revert: ui('<path d="M4 9h11a5 5 0 1 1 0 10h-3"/><path d="M7 5 3 9l4 4"/>'),
      lock: ui('<rect x="5" y="10.5" width="14" height="9" rx="2"/><path d="M8 10.5V7.5a4 4 0 0 1 8 0v3"/>', 1.6)
    };
    function docIcon() { return ui('<rect x="5" y="3" width="14" height="18" rx="2"/><path d="M8.5 8h7M8.5 12h7M8.5 16h4"/>'); }

    var DEV_SPECS = {
      mobile: { portrait: [390, 810], landscape: [810, 390] },
      tablet: { portrait: [768, 1010], landscape: [1024, 720] },
      desktop: { portrait: [960, 760], landscape: [960, 760] }
    };
    var DEV_LABEL = { mobile: "Celular", tablet: "Tablet", desktop: "Desktop" };

    var VAR_LABELS = {
      "application.name": "Nome do app", "application.logo_uri": "Logo (URI)", "application.id": "ID do app",
      "user.email": "E-mail do usuário", "user.name": "Nome do usuário",
      "user.city": "Cidade", "user.country": "País", "user.source_ip": "Endereço IP",
      "inviter.name": "Quem convidou", "organization.name": "Organização (slug)",
      "organization.display_name": "Organização (nome)", "friendly_name": "Nome amigável",
      "prompt.name": "Prompt", "locale": "Idioma (locale)", "tenant": "Tenant",
      "url": "URL de ação", "link": "Link de ação", "code": "Código (OTP)", "support_url": "URL de suporte"
    };
    var GROUP_LABELS = { application: "Aplicação", user: "Usuário", organization: "Organização", inviter: "Convite", prompt: "Prompt", _scalar: "Parâmetros" };
    var GROUP_SEQ = ["application", "user", "organization", "inviter", "prompt", "_scalar"];

    // ---- small helpers ----
    function ls(k, d) { try { var v = localStorage.getItem(k); return v == null ? d : v; } catch (e) { return d; } }
    function save(k, v) { try { localStorage.setItem(k, v); } catch (e) {} }
    function esc(s) { return String(s == null ? "" : s).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;"); }
    function escapeHtml(s) { return String(s == null ? "" : s).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;"); }
    function highlight(s) { return escapeHtml(s).replace(/(\{\{[\s\S]*?\}\}|\{%[\s\S]*?%\})/g, '<span class="lq">$1</span>'); }
    function el(id) { return document.getElementById(id); }
    function themeLabel(key) { for (var i = 0; i < THEMES.length; i++) { if (THEMES[i].key === key) return THEMES[i].label; } return key; }
    function flatten(obj, prefix, out) {
      out = out || [];
      Object.keys(obj || {}).forEach(function (k) {
        if (k === "_meta") return;
        var v = obj[k]; var path = prefix ? prefix + "." + k : k;
        if (v && typeof v === "object" && !Array.isArray(v)) flatten(v, path, out);
        else out.push({ path: path, value: v });
      });
      return out;
    }
    function setPath(obj, path, value) {
      var parts = path.split("."); var cur = obj;
      for (var i = 0; i < parts.length - 1; i++) {
        if (cur[parts[i]] == null || typeof cur[parts[i]] !== "object") cur[parts[i]] = {};
        cur = cur[parts[i]];
      }
      cur[parts[parts.length - 1]] = value;
    }
    // dotted-path overrides -> nested object the server deep-merges
    function nest(ov) { var o = {}; Object.keys(ov || {}).forEach(function (p) { setPath(o, p, ov[p]); }); return o; }

    // ---- state ----
    var displayKeys = orderedKeys();
    var key = ls("eml.key", displayKeys[0]);
    if (!BYNAME[key]) key = displayKeys[0];
    var theme = ls("eml.theme", "quiet");
    if (!themeValid(theme)) theme = THEMES[0].key;
    var device = ls("eml.device", "desktop");
    var orient = ls("eml.orient", "portrait");
    var view = ls("eml.view", "preview");
    var collapsed = ls("eml.collapsed", "0") === "1";
    var query = "";
    var panel = false;
    var overrides = {};
    try { overrides = JSON.parse(ls("eml.vars", "{}")) || {}; } catch (e) { overrides = {}; }

    var lastHtml = "", lastSource = "", lastMeta = null, copied = false, previewTimer = null;

    function themeValid(t) { return THEMES.some(function (x) { return x.key === t; }); }
    function orderedKeys() {
      var out = [], seen = {};
      GROUPS.concat(["__rest__"]).forEach(function (g) {
        ENTRIES.forEach(function (e) {
          if (seen[e.name]) return;
          var grp = e.group || "__rest__";
          if (g === "__rest__" ? !GROUPS.indexOf(grp) >= 0 || GROUPS.indexOf(grp) === -1 : grp === g) {
            if (g === "__rest__" && GROUPS.indexOf(grp) !== -1) return;
            out.push(e.name); seen[e.name] = 1;
          }
        });
      });
      ENTRIES.forEach(function (e) { if (!seen[e.name]) { out.push(e.name); seen[e.name] = 1; } });
      return out;
    }
    function changedCount() { return Object.keys(overrides[key] || {}).length; }
    function isPageKind() { return (BYNAME[key] || {}).kind === "universal_login"; }
    function pageUrl() {
      var ov = overrides[key] || {};
      var t = ov.tenant || (FIXVARS[key] && FIXVARS[key].tenant) || "acme";
      return t + ".auth0.com/u/login";
    }

    // ---- nav (sidebar) ----
    function renderNav() {
      var q = query.trim().toLowerCase();
      var sections = GROUPS.concat(["Outros"]);
      var html = "";
      sections.forEach(function (g) {
        var items = ENTRIES.filter(function (e) {
          var grp = (e.group && GROUPS.indexOf(e.group) !== -1) ? e.group : "Outros";
          if (grp !== g) return false;
          if (!q) return true;
          var hay = ((e.title || "") + " " + (e.description || "") + " " + e.name).toLowerCase();
          return hay.indexOf(q) !== -1;
        });
        if (!items.length) return;
        html += '<div class="nav-group">' + esc(g) + "</div>";
        items.forEach(function (e) {
          html += '<button class="item' + (e.name === key ? " active" : "") + '" data-item="' + esc(e.name) + '">' +
            '<span class="item-ic">' + (MAIL_ICONS[e.name] || docIcon()) + "</span>" +
            '<span class="item-tx"><div class="item-t">' + esc(e.title || e.name) + "</div>" +
            '<div class="item-d">' + esc(e.description || "") + "</div></span></button>";
        });
      });
      el("nav").innerHTML = html || '<div class="nav-group">Nenhum resultado</div>';
    }

    // ---- toolbar ----
    function seg(group, opts, current, opt) {
      opt = opt || {};
      var cls = "seg" + (opt.icons ? " icons" : "") + (opt.disabled ? " disabled" : "");
      var btns = opts.map(function (o) {
        var inner = (o.icon ? "<span>" + o.icon + "</span>" : "") + (o.label ? "<span>" + esc(o.label) + "</span>" : "");
        return '<button data-seg="' + group + '" data-val="' + esc(o.value) + '" class="' + (current === o.value ? "on" : "") +
          '" title="' + esc(o.title || o.label || "") + '"' + (opt.disabled ? " disabled" : "") + ">" + inner + "</button>";
      }).join("");
      return '<div class="' + cls + '" data-seg-group="' + group + '">' + btns + "</div>";
    }
    function renderToolbar() {
      var entry = BYNAME[key] || { title: key };
      var cnt = changedCount();
      var html =
        '<button class="icon-btn" data-act="collapse" title="Recolher/expandir">' + UI.sidebar + "</button>" +
        '<div class="bar-title"><div class="t">' + esc(entry.title || key) + '</div><div class="s">' + esc(key) + ".liquid</div></div>" +
        '<div class="spacer"></div>' +
        '<span class="seg-label">Estilo</span>' +
        seg("theme", THEMES.map(function (t) { return { value: t.key, label: t.label }; }), theme, { disabled: isPageKind() }) +
        seg("device", [
          { value: "mobile", icon: UI.phone, title: "Celular" },
          { value: "tablet", icon: UI.tablet, title: "Tablet" },
          { value: "desktop", icon: UI.desktop, title: "Desktop" }
        ], device, { icons: true }) +
        seg("orient", [
          { value: "portrait", icon: UI.portrait, title: "Retrato" },
          { value: "landscape", icon: UI.landscape, title: "Paisagem" }
        ], orient, { icons: true, disabled: device === "desktop" }) +
        seg("view", [
          { value: "preview", icon: UI.eye, label: "Prévia" },
          { value: "source", icon: UI.code, label: "Liquid" }
        ], view) +
        '<button class="vars-btn' + (panel ? " on" : "") + '" data-act="vars" title="Editar variáveis Liquid">' +
        "<span>" + UI.sliders + "</span><span>Variáveis</span>" +
        (cnt ? '<span class="vars-badge">' + cnt + "</span>" : "") + "</button>";
      el("bar").innerHTML = html;
    }

    // ---- stage ----
    function dims() {
      var ori = device === "desktop" ? "landscape" : orient;
      return DEV_SPECS[device][ori];
    }
    function clientHTML(w, h) {
      var size = DEV_LABEL[device] + " · " + w + "×" + h;
      var dots = '<span class="dot"></span><span class="dot"></span><span class="dot"></span>';
      var bar, meta, iframe;
      if (isPageKind()) {
        // A full Universal Login page: browser chrome (address bar) + a full-size iframe.
        bar = '<div class="client-bar browser">' + dots +
          '<div class="addr"><span>' + UI.lock + "</span><span>" + esc(pageUrl()) + "</span></div>" +
          '<span class="w">' + size + "</span></div>";
        meta = "";
        iframe = '<iframe id="frame" title="preview" style="height:100%;width:100%"></iframe>';
      } else {
        // An email: email-client chrome (subject/sender/recipient) + auto-fit iframe.
        bar = '<div class="client-bar">' + dots +
          '<span class="lbl">Caixa de entrada</span><span class="w">' + size + "</span></div>";
        meta = '<div class="client-meta"><span class="avatar">' + monogram() + "</span>" +
          '<div class="meta-tx"><div class="meta-subj" id="m-subj"></div>' +
          '<div class="meta-from"><b id="m-from-name"></b><span id="m-from-addr"></span></div>' +
          '<div class="meta-to" id="m-to"></div></div>' +
          '<span class="meta-time">agora</span></div>';
        iframe = '<iframe id="frame" title="preview" scrolling="no" style="height:600px"></iframe>';
      }
      return '<div class="client" style="width:' + w + "px;height:" + h + 'px">' + bar + meta +
        '<div class="frame-wrap">' + iframe + "</div></div>";
    }
    function sourceHTML() {
      return '<div class="source"><div class="source-bar">' +
        '<span class="nm"><b>' + esc(key) + ".liquid</b>  ·  " +
        (isPageKind() ? "página Universal Login" : "tema " + esc(themeLabel(theme))) + "</span>" +
        '<div class="spacer"></div>' +
        '<button class="copy-btn" data-act="copy"><span>' + (copied ? UI.check : UI.copy) + "</span>" +
        "<span>" + (copied ? "Copiado" : "Copiar") + "</span></button></div>" +
        '<pre id="src"></pre></div>';
    }
    function fitFrame(f) {
      try {
        var d = f.contentWindow.document;
        var hgt = Math.max(d.documentElement.scrollHeight, d.body.scrollHeight);
        f.style.height = (hgt + 2) + "px";
      } catch (e) {}
    }
    function paintChrome() {
      var m = lastMeta || { subject: (BYNAME[key] || {}).subject || "", from_name: "Acme", from_addr: "nao-responder@acme.com", to: "" };
      var s = el("m-subj"); if (s) s.textContent = m.subject;
      var fn = el("m-from-name"); if (fn) fn.textContent = m.from_name;
      var fa = el("m-from-addr"); if (fa) fa.textContent = " <" + m.from_addr + ">";
      var to = el("m-to"); if (to) to.textContent = "para " + m.to;
    }
    function paintIframe() {
      var f = el("frame"); if (!f) return;
      // The ULP page sizes itself (min-height:100vh) and fills the device window; emails
      // are short, so we auto-fit the iframe height to content and let the window scroll.
      f.onload = isPageKind() ? null : function () { fitFrame(f); };
      f.srcdoc = lastHtml || "";
    }
    function paintSource() { var pre = el("src"); if (pre) pre.innerHTML = highlight(lastSource); }
    function renderStage() {
      var stage = el("stage");
      if (view === "preview") {
        var d = dims();
        stage.innerHTML = clientHTML(d[0], d[1]);
        paintIframe(); paintChrome();
      } else {
        stage.innerHTML = sourceHTML();
        paintSource();
      }
    }
    function updateStageSize() {
      var c = el("stage").querySelector(".client");
      if (!c) { renderStage(); return; }
      var d = dims();
      c.style.width = d[0] + "px"; c.style.height = d[1] + "px";
      var w = c.querySelector(".client-bar .w");
      if (w) w.textContent = DEV_LABEL[device] + " · " + d[0] + "×" + d[1];
    }

    // ---- drawer (variables) ----
    function renderDrawer() {
      var host = el("drawer-host");
      el("main").classList.toggle("with-drawer", panel);
      if (!panel) { host.innerHTML = ""; return; }
      var fields = flatten(FIXVARS[key] || {});
      var grouped = {};
      fields.forEach(function (f) {
        var top = f.path.indexOf(".") > -1 ? f.path.split(".")[0] : "_scalar";
        (grouped[top] = grouped[top] || []).push(f);
      });
      var curOv = overrides[key] || {};
      var groups = GROUP_SEQ.filter(function (g) { return grouped[g]; });
      Object.keys(grouped).forEach(function (g) { if (groups.indexOf(g) === -1) groups.push(g); });
      var body = groups.map(function (g) {
        var rows = grouped[g].map(function (f) {
          var changed = Object.prototype.hasOwnProperty.call(curOv, f.path);
          var val = changed ? curOv[f.path] : f.value;
          return '<div class="field' + (changed ? " changed" : "") + '">' +
            '<div class="field-top"><label class="field-l">' + esc(VAR_LABELS[f.path] || f.path) + "</label>" +
            '<button class="field-revert" data-revert="' + esc(f.path) + '" title="Restaurar valor">' + UI.revert + "</button></div>" +
            '<input class="field-i" data-path="' + esc(f.path) + '" value="' + esc(val == null ? "" : val) + '">' +
            '<div class="field-tok">{{ ' + esc(f.path) + " }}</div></div>";
        }).join("");
        return '<div class="fgroup"><div class="fgroup-t">' + esc(GROUP_LABELS[g] || g) + "</div>" + rows + "</div>";
      }).join("");
      var cnt = changedCount();
      host.innerHTML = '<div class="drawer">' +
        '<div class="drawer-head"><div><div class="drawer-t">Variáveis Liquid</div>' +
        '<div class="drawer-s">' + esc(key) + ".liquid</div></div>" +
        '<button class="icon-btn" data-act="close-drawer" title="Fechar">' + UI.close + "</button></div>" +
        '<div class="drawer-note">Pré-visualização: edite os valores para ver os placeholders mudarem ao vivo. Não altera o arquivo .liquid.</div>' +
        '<div class="drawer-body">' + body + "</div>" +
        '<div class="drawer-foot"><button class="reset-btn" data-act="reset-vars"' + (cnt ? "" : " disabled") + ">" +
        (cnt ? "Restaurar padrões · " + cnt : "Sem alterações") + "</button></div></div>";
    }

    // ---- data fetching ----
    function fetchPreview() {
      var k = key, t = theme, bodyStr = JSON.stringify(nest(overrides[key]));
      var opts = { method: "POST", headers: { "Content-Type": "application/json" }, body: bodyStr };
      fetch("/render/" + encodeURIComponent(k) + "?theme=" + t, opts)
        .then(function (r) { return r.text(); })
        .then(function (html) { if (k === key && t === theme) { lastHtml = html; if (view === "preview") paintIframe(); } })
        .catch(function () {});
      fetch("/api/meta/" + encodeURIComponent(k) + "?theme=" + t, opts)
        .then(function (r) { return r.json(); })
        .then(function (m) { if (k === key) { lastMeta = m; if (view === "preview") paintChrome(); } })
        .catch(function () {});
    }
    function fetchSource() {
      var k = key, t = theme;
      fetch("/render/" + encodeURIComponent(k) + "?theme=" + t + "&source=1")
        .then(function (r) { return r.text(); })
        .then(function (src) { if (k === key && t === theme) { lastSource = src; if (view === "source") paintSource(); } })
        .catch(function () {});
    }
    function schedulePreview() {
      if (previewTimer) clearTimeout(previewTimer);
      previewTimer = setTimeout(fetchPreview, 180);
    }

    // ---- state setters ----
    function setKey(k) { if (k === key || !BYNAME[k]) return; key = k; save("eml.key", k); renderNav(); renderToolbar(); renderStage(); renderDrawer(); fetchPreview(); fetchSource(); }
    function setTheme(t) { if (t === theme) return; theme = t; save("eml.theme", t); renderToolbar(); renderStage(); fetchPreview(); fetchSource(); }
    function setDevice(d) { if (d === device) return; device = d; save("eml.device", d); renderToolbar(); if (view === "preview") updateStageSize(); }
    function setOrient(o) { if (o === orient || device === "desktop") return; orient = o; save("eml.orient", o); renderToolbar(); if (view === "preview") updateStageSize(); }
    function setView(v) { if (v === view) return; view = v; save("eml.view", v); renderToolbar(); renderStage(); if (v === "source" && !lastSource) fetchSource(); }
    function toggleCollapse(force) { collapsed = (force === undefined) ? !collapsed : force; save("eml.collapsed", collapsed ? "1" : "0"); el("app").classList.toggle("collapsed", collapsed); }
    function togglePanel() { panel = !panel; renderToolbar(); renderDrawer(); }
    function setVar(path, val) { overrides[key] = overrides[key] || {}; overrides[key][path] = val; save("eml.vars", JSON.stringify(overrides)); }
    function revertVar(path) {
      if (overrides[key]) { delete overrides[key][path]; if (!Object.keys(overrides[key]).length) delete overrides[key]; }
      save("eml.vars", JSON.stringify(overrides));
      renderDrawer(); renderToolbar(); fetchPreview();
    }
    function resetVars() { delete overrides[key]; save("eml.vars", JSON.stringify(overrides)); renderDrawer(); renderToolbar(); fetchPreview(); }
    function doCopy() {
      try { navigator.clipboard.writeText(lastSource); } catch (e) {}
      copied = true; renderStage();
      setTimeout(function () { copied = false; if (view === "source") renderStage(); }, 1400);
    }

    // ---- events (delegated) ----
    el("app").addEventListener("click", function (e) {
      var t = e.target.closest("[data-act],[data-seg],[data-item],[data-revert]");
      if (!t) return;
      if (t.hasAttribute("data-item")) return setKey(t.getAttribute("data-item"));
      if (t.hasAttribute("data-seg")) {
        var g = t.getAttribute("data-seg"), v = t.getAttribute("data-val");
        if (g === "theme") return setTheme(v);
        if (g === "device") return setDevice(v);
        if (g === "orient") return setOrient(v);
        if (g === "view") return setView(v);
        return;
      }
      if (t.hasAttribute("data-revert")) return revertVar(t.getAttribute("data-revert"));
      var act = t.getAttribute("data-act");
      if (act === "collapse") return toggleCollapse();
      if (act === "float-open") return toggleCollapse(false);
      if (act === "vars") return togglePanel();
      if (act === "close-drawer") { panel = false; renderToolbar(); renderDrawer(); return; }
      if (act === "reset-vars") return resetVars();
      if (act === "copy") return doCopy();
    });
    el("float-open").setAttribute("data-act", "float-open");
    el("app").addEventListener("input", function (e) {
      if (e.target.id === "search") { query = e.target.value; renderNav(); return; }
      if (e.target.classList.contains("field-i")) {
        var path = e.target.getAttribute("data-path");
        setVar(path, e.target.value);
        var field = e.target.closest(".field"); if (field) field.classList.add("changed");
        renderToolbar();
        schedulePreview();
      }
    });

    // ---- boot ----
    el("brand-mono").innerHTML = monogram();
    el("search-ic").innerHTML = UI.search;
    el("float-open").innerHTML = UI.sidebar;
    el("app").classList.toggle("collapsed", collapsed);
    renderNav();
    renderToolbar();
    renderStage();
    renderDrawer();
    fetchPreview();
    fetchSource();
  })();
  </script>
</body>
</html>
