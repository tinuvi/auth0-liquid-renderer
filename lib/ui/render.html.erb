<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= h(@entry[:title]) %> · Auth0 Liquid Renderer</title>
  <style>
    :root { color-scheme: light dark; }
    body { font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif; line-height: 1.5;
           max-width: 70rem; margin: 1.5rem auto; padding: 0 1rem; }
    a { color: #635dff; text-decoration: none; }
    a:hover { text-decoration: underline; }
    .bar { display: flex; align-items: baseline; gap: 1rem; flex-wrap: wrap; }
    .tag { font-size: 0.75rem; background: #eee; color: #444; border-radius: 999px; padding: 0.1rem 0.6rem; }
    .cols { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; align-items: start; }
    @media (max-width: 60rem) { .cols { grid-template-columns: 1fr; } }
    h2 { font-size: 0.95rem; text-transform: uppercase; letter-spacing: 0.04em; color: #666; }
    iframe { width: 100%; height: 32rem; border: 1px solid #ddd; border-radius: 6px; background: #fff; }
    textarea { width: 100%; height: 26rem; font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
               font-size: 0.8rem; box-sizing: border-box; border: 1px solid #ddd; border-radius: 6px; padding: 0.6rem; }
    button { background: #635dff; color: #fff; border: 0; border-radius: 6px; padding: 0.55rem 1rem;
             font-size: 0.9rem; cursor: pointer; margin-top: 0.5rem; }
    .error { background: #fdecec; border: 1px solid #f5b5b5; color: #a40000; border-radius: 6px;
             padding: 0.75rem 1rem; white-space: pre-wrap; }
  </style>
</head>
<body>
  <p><a href="/">&larr; All templates</a></p>
  <div class="bar">
    <h1 style="margin:0"><%= h(@entry[:title]) %></h1>
    <span class="tag"><%= h(@entry[:kind]) %></span>
    <code><%= h(@name) %>.liquid</code>
    <a href="/render/<%= h(@name) %>?_raw=1">view raw &rarr;</a>
  </div>

  <% if @error %>
    <h2>Render error</h2>
    <p class="error"><%= h(@error) %></p>
  <% end %>

  <div class="cols">
    <div>
      <h2>Preview</h2>
      <% if @output %>
        <iframe title="rendered output" srcdoc="<%= h(@output) %>"></iframe>
      <% else %>
        <p>No output — fix the error above and render again.</p>
      <% end %>
    </div>
    <div>
      <h2>Variables (resolved context)</h2>
      <form id="ctx-form">
        <textarea id="ctx" spellcheck="false"><%= h(JSON.pretty_generate(@context)) %></textarea>
        <button type="submit">Render with these variables</button>
      </form>
      <p style="font-size:0.8rem;color:#666">
        Edit the JSON and re-render. Defaults &lt; <code>_fixtures/<%= h(@name) %>.json</code> &lt; your edits.
      </p>
    </div>
  </div>

  <script>
    // Deep-override the context by POSTing the edited JSON back to this route.
    document.getElementById("ctx-form").addEventListener("submit", async (event) => {
      event.preventDefault();
      const response = await fetch(window.location.pathname, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: document.getElementById("ctx").value,
      });
      const html = await response.text();
      document.open();
      document.write(html);
      document.close();
    });
  </script>
</body>
</html>
